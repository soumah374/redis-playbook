# Redis Sentinel Configuration
# Généré par Ansible — {{ ansible_date_time.date }}
# Nœud : {{ inventory_hostname }} | Rôle : {{ 'master' if inventory_hostname in groups['redis_master'] else 'replica' }}

port {{ sentinel_port }}
bind 0.0.0.0
protected-mode no
daemonize yes
logfile /var/log/redis/sentinel.log
pidfile /var/run/redis/sentinel.pid

# IMPORTANT : sentinel monitor DOIT être placé AVANT sentinel auth-pass
sentinel monitor {{ sentinel_master_name }} {{ monitor_ip }} {{ redis_port }} {{ sentinel_quorum }}

sentinel auth-pass {{ sentinel_master_name }} {{ redis_password }}

sentinel down-after-milliseconds {{ sentinel_master_name }} {{ down_after_ms }}

sentinel failover-timeout {{ sentinel_master_name }} {{ failover_timeout }}

sentinel parallel-syncs {{ sentinel_master_name }} {{ parallel_syncs }}
