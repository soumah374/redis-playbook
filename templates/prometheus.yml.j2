# Géré par Ansible — configuration Prometheus
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  - job_name: redis_exporter
    static_configs:
      - targets:
{% for host in groups['redis_all'] %}
          - '{{ hostvars[host].ansible_host }}:{{ redis_exporter_port }}'
{% endfor %}
        labels:
          group: redis
